{
  "info": {
    "_postman_id": "7f24a0aa-7b6c-49c5-a29f-0d4b4e43d5d3",
    "name": "CasaCalcuta API",
    "description": "Colección inicial del backend de CasaCalcuta.\n\n## Autenticación\n\nLa API usa JWT. Primero ejecutá `auth/login` para guardar `access_token` en la variable de entorno.\n\n## Usuarios\n\nLos endpoints de `usuarios` requieren Bearer token.\n\n### Base URL\n\nUsar la variable `{{base_url}}`.\n\n### Notas\n\n- La API expone respuestas JSON.\n- `contrasena` se envía en texto plano y Laravel la guarda hasheada.\n- `rol_id` debe apuntar a un rol existente.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "auth",
      "description": "Autenticación JWT de la API.",
      "item": [
        {
          "name": "login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Obtiene un JWT para usar en los endpoints protegidos."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.access_token) {",
                  "  pm.collectionVariables.set('access_token', body.access_token);",
                  "  pm.environment.set('access_token', body.access_token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "me"
              ]
            },
            "description": "Devuelve el usuario autenticado del token actual."
          }
        },
        {
          "name": "refresh",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/refresh",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "refresh"
              ]
            },
            "description": "Genera un nuevo JWT y reemplaza el token guardado."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.access_token) {",
                  "  pm.collectionVariables.set('access_token', body.access_token);",
                  "  pm.environment.set('access_token', body.access_token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "logout"
              ]
            },
            "description": "Invalida el JWT actual."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.unset('access_token');",
                  "pm.environment.unset('access_token');"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "usuarios",
      "description": "Operaciones REST sobre la entidad `Usuario`.",
      "item": [
        {
          "name": "Listar usuarios",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/usuarios?per_page=15",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "usuarios"
              ],
              "query": [
                {
                  "key": "per_page",
                  "value": "15"
                }
              ]
            },
            "description": "Devuelve un listado paginado de usuarios con su `rol`."
          }
        },
        {
          "name": "Obtener usuario",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/usuarios/{{usuario_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "usuarios",
                "{{usuario_id}}"
              ]
            },
            "description": "Devuelve un usuario puntual por `id_usuario`."
          }
        },
        {
          "name": "Crear usuario",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Admin\",\n  \"apellido\": \"Sistema\",\n  \"email\": \"admin@example.com\",\n  \"contrasena\": \"password\",\n  \"contrasena_confirmation\": \"password\",\n  \"activo\": true,\n  \"rol_id\": {{rol_id}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/usuarios",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "usuarios"
              ]
            },
            "description": "Crea un nuevo usuario. `contrasena` se envía como texto plano y se guarda hasheada en la base."
          }
        },
        {
          "name": "Actualizar usuario",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Admin\",\n  \"apellido\": \"Sistema\",\n  \"email\": \"admin@example.com\",\n  \"contrasena\": \"password\",\n  \"contrasena_confirmation\": \"password\",\n  \"activo\": true,\n  \"rol_id\": {{rol_id}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/usuarios/{{usuario_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "usuarios",
                "{{usuario_id}}"
              ]
            },
            "description": "Actualiza un usuario existente. Los campos son opcionales salvo que quieras modificar `rol_id` o `email`."
          }
        },
        {
          "name": "Eliminar usuario",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/usuarios/{{usuario_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "usuarios",
                "{{usuario_id}}"
              ]
            },
            "description": "Elimina un usuario por `id_usuario`. Responde con `204 No Content`."
          }
        }
      ]
    }
  ]
}
