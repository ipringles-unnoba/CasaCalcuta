{
  "info": {
    "_postman_id": "7f24a0aa-7b6c-49c5-a29f-0d4b4e43d5d3",
    "name": "CasaCalcuta API",
    "description": "Colección del backend API de CasaCalcuta.\n\n## Flujo\n\n1. Ejecutar `auth/login`.\n2. Usar `access_token` para los endpoints protegidos.\n3. Crear primero entidades base (`usuarios`, `familias`, `comisiones`, etc.) y luego sus relaciones.\n\n## Variables\n\nUsar `{{base_url}}` y los ids de entorno para probar los endpoints.\n\n## Notas\n\n- La API responde JSON.\n- `contrasena` se envía en texto plano y Laravel la hashea.\n- Los endpoints protegidos usan `Bearer {{access_token}}`.\n- `auditorias` es solo lectura.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.access_token) {",
                  "  pm.collectionVariables.set('access_token', body.access_token);",
                  "  pm.environment.set('access_token', body.access_token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "me"]
            }
          }
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "refresh"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "usuarios",
      "item": [
        {
          "name": "Listar",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/usuarios?per_page=15",
              "host": ["{{base_url}}"],
              "path": ["api", "usuarios"],
              "query": [{ "key": "per_page", "value": "15" }]
            }
          }
        },
        {
          "name": "Obtener",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/usuarios/{{usuario_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "usuarios", "{{usuario_id}}"]
            }
          }
        },
        {
          "name": "Crear",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Admin\",\n  \"apellido\": \"Sistema\",\n  \"email\": \"admin@example.com\",\n  \"contrasena\": \"password\",\n  \"contrasena_confirmation\": \"password\",\n  \"activo\": true,\n  \"rol_id\": {{rol_id}}\n}" },
            "url": { "raw": "{{base_url}}/api/usuarios", "host": ["{{base_url}}"], "path": ["api", "usuarios"] }
          }
        },
        {
          "name": "Actualizar",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Admin\",\n  \"apellido\": \"Sistema\",\n  \"email\": \"admin@example.com\",\n  \"contrasena\": \"password\",\n  \"contrasena_confirmation\": \"password\",\n  \"activo\": true,\n  \"rol_id\": {{rol_id}}\n}" },
            "url": { "raw": "{{base_url}}/api/usuarios/{{usuario_id}}", "host": ["{{base_url}}"], "path": ["api", "usuarios", "{{usuario_id}}"] }
          }
        },
        {
          "name": "Eliminar",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/usuarios/{{usuario_id}}", "host": ["{{base_url}}"], "path": ["api", "usuarios", "{{usuario_id}}"] }
          }
        },
        {
          "name": "Notificaciones",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/usuarios/{{usuario_id}}/notificaciones", "host": ["{{base_url}}"], "path": ["api", "usuarios", "{{usuario_id}}", "notificaciones"] }
          }
        },
        {
          "name": "Sync notificaciones",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"notificaciones\": [{{notificacion_id}}]\n}" },
            "url": { "raw": "{{base_url}}/api/usuarios/{{usuario_id}}/notificaciones/sync", "host": ["{{base_url}}"], "path": ["api", "usuarios", "{{usuario_id}}", "notificaciones", "sync"] }
          }
        }
      ]
    },
