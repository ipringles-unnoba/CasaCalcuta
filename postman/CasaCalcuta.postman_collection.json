              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"puntaje_menores\": 2,\n  \"puntaje_alimentacion\": 2,\n  \"puntaje_asistencia\": 1,\n  \"puntaje_participacion\": 0\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/familias/{{familia_id}}/evaluar-prioridad",
              "host": ["{{base_url}}"],
              "path": ["api", "familias", "{{familia_id}}", "evaluar-prioridad"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (pm.response.code === 200) {",
                  "  pm.test('Prioridad calculada correctamente', () => {",
                  "    pm.expect(body).to.have.property('prioridad_social');",
                  "    pm.expect(body).to.have.property('puntaje_prioridad');",
                  "    pm.expect(body).to.have.property('puntaje_menores');",
                  "    pm.expect(body).to.have.property('puntaje_alimentacion');",
                  "    pm.expect(body).to.have.property('puntaje_asistencia');",
                  "    pm.expect(body).to.have.property('puntaje_participacion');",
                  "    pm.expect(body).to.have.property('fecha_ultima_evaluacion');",
                  "    pm.expect(body).to.have.nested.property('evaluado_por.id_usuario');",
                  "    pm.expect(['muy_baja', 'baja', 'media', 'alta', 'muy_alta']).to.include(body.prioridad_social);",
                  "    pm.expect(body.puntaje_prioridad).to.be.at.least(0);",
                  "  });",
                  "} else if (pm.response.code === 403) {",
                  "  pm.test('Acceso denegado - se requiere rol Administrador o Coordinador', () => {",
                  "    pm.expect(body).to.have.property('message');",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        },
