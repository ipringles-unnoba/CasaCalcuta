            "url": {
              "raw": "{{base_url}}/api/familias/{{familia_id}}/evaluar-prioridad",
              "host": ["{{base_url}}"],
              "path": ["api", "familias", "{{familia_id}}", "evaluar-prioridad"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (pm.response.code === 200) {",
                  "  pm.test('Prioridad automatica por participacion activa', () => {",
                  "    pm.expect(body.prioridad_social).to.equal('muy_alta');",
                  "    pm.expect(body.puntaje_participacion).to.equal(2);",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
